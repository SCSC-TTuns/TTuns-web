# Local sugang dataset path (optional)
SNUTT_LOCAL_DATA_DIR=data/sugang

# Cache / rate-limit
SNUTT_CACHE_TTL_SECONDS=1800      # lecture list cache TTL, default 1800s
SNUTT_RATE_LIMIT_WINDOW_MS=60000  # per-IP window, default 60000ms
SNUTT_RATE_LIMIT_MAX=30           # max requests per window, default 30

# Mixpanel
NEXT_PUBLIC_MIXPANEL_TOKEN=YOUR_MIXPANEL_TOKEN
